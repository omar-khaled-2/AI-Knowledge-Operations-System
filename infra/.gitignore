# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data
*.tfvars
*.tfvars.json

# Ignore override files as they are usually used for local dev
terraform.rc
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
.terraform.d/

# Ignore lock files (uncomment if you want to ignore .terraform.lock.hcl)
# .terraform.lock.hcl

# Ignore plan output files
*.tfplan

# Ignore generated files
*.backup
*.log

# Ignore IDE files
.idea/
.vscode/
*.swp
*.swo
*~

# Ignore OS files
.DS_Store
Thumbs.db

# Ignore sensitive files
*.pem
*.key
*.p12
*.pfx
secrets.tfvars
