{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["superpowers@git+https://github.com/obra/superpowers.git"],
  "mcp": {
    "trello": {
      "type": "local",
      "command": ["dotenv", "--", "bunx", "@delorenj/mcp-server-trello"]
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["bunx", "-y", "chrome-devtools-mcp@latest"]
    },
    "shadcn": {
      "type": "local",
      "command": ["bunx", "-y", "shadcn@latest", "mcp"],
      "enabled": true
    }
  }
}
